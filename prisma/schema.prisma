generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  ADMIN
}

enum VentureStage {
  IDEA
  PROTOTYPE
  MVP
  GROWTH
}

enum Availability {
  NONE
  LOOKING_PARTNERS
  MENTORING
  FREELANCE
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         Role      @default(STUDENT)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  profile      Profile?
  ventures     Venture[]
  messages     Message[]
  sessions     Session[]
  accounts     Account[]
  trainingProgress TrainingProgress[]
}

model Profile {
  id         String  @id @default(cuid())
  userId     String  @unique
  fullName   String?
  bio        String? @db.Text
  avatarKey  String?
  website    String?
  linkedin   String?
  github     String?
  instagram  String?
  roleTitle  String?
  availability Availability @default(NONE)
  interests  String[] @default([])
  links      Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Venture {
  id          String         @id @default(cuid())
  ownerId     String
  title       String
  summary     String         @db.Text
  stage       VentureStage   @default(IDEA)
  tags        String[]
  coverKey    String?
  featured    Boolean        @default(false)
  published   Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  owner       User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  updates     VentureUpdate[]
  attachments Attachment[]
}

model VentureUpdate {
  id         String   @id @default(cuid())
  ventureId  String
  content    String   @db.Text
  createdAt  DateTime @default(now())

  venture Venture @relation(fields: [ventureId], references: [id], onDelete: Cascade)
}

model Attachment {
  id         String   @id @default(cuid())
  ventureId  String
  name       String
  url        String
  blobKey    String?
  mimeType   String?
  size       Int?
  createdAt  DateTime @default(now())

  venture Venture @relation(fields: [ventureId], references: [id], onDelete: Cascade)
}

model TrainingModule {
  id          String   @id @default(cuid())
  title       String
  category    String
  path        String   // relative path under public/modulos de formacion
  description String?  @db.Text
  createdAt   DateTime @default(now())
}

model TrainingProgress {
  id           String   @id @default(cuid())
  userId       String
  resourcePath String
  progress     Float    @default(1)
  openedAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, resourcePath])
}

model Message {
  id        String       @id @default(cuid())
  userId    String?
  role      MessageRole  @default(USER)
  content   String       @db.Text
  threadId  String?
  createdAt DateTime     @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@index([userId])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
